# Agent Engine Service 环境配置

# 服务配置
APP_NAME="Agent Engine Service"
DEBUG=false
HOST=0.0.0.0
PORT=8000
# Worker 进程数量，生产环境建议设置为 CPU 核心数
WORKERS=1

# 数据库配置
# SQLite (默认)
DATABASE_URL=sqlite+aiosqlite:///:memory:

# PostgreSQL 示例
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_engine

# MySQL 示例
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/agent_engine

# 健康状态上报配置
HEALTH_REPORT_INTERVAL=60
# 是否启用健康状态上报（true/false）。在测试或轻量部署中可关闭以避免后台任务影响测试稳定性。
HEALTH_REPORTER_ENABLED=false

# 日志配置
LOG_LEVEL=INFO
# LOG_FILE=logs/agent_engine.log

# Skill 配置（可选）
# 不配置时默认使用 src/skills
# 示例（Windows）: SKILLS_ROOT=D:/AI/05 VS code/L3-Agent/AgentEngine/src/skills
SKILLS_ROOT=

# Skill 增量刷新周期（秒）
# 用于定时发现 Pivot 等外部写入的新 skill，默认 600 秒（10 分钟）
SKILL_REFRESH_INTERVAL_SECONDS=600

# Skill 配置（可选）
# 不配置时默认使用 src/skills
# 示例（Windows）: SKILLS_ROOT=D:/AI/05 VS code/L3-Agent/AgentEngine/src/skills
SKILLS_ROOT=src/skills
